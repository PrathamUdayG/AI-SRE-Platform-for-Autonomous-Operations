# ============================================
# AI-SRE Platform - Environment Variables Template
# ============================================

# ---------- Global ----------
AI_SRE_APP_NAME=AI_SRE
AI_SRE_APP_ENV=local
AI_SRE_DEBUG=true
AI_SRE_LOG_LEVEL=INFO
AI_SRE_LOG_JSON=false

# ---------- PostgreSQL / TimescaleDB ----------
# Note: DATABASE_ prefix is used directly without AI_SRE_ prefix
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aisre
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ---------- Hostinger VPS ----------
AI_SRE_HOSTINGER__SSH_HOST=localhost
