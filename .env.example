# ============================================
# AI-SRE Platform - Environment Variables
# ============================================
# Prefix all vars with AI_SRE_ as per settings.py
# Use double underscore (__) for nested configs

# ---------- Global ----------
AI_SRE_APP_ENV=local
AI_SRE_DEBUG=true
AI_SRE_SECRET_KEY=replace_this_with_a_real_secret_in_production

# ---------- PostgreSQL / TimescaleDB ----------
AI_SRE_DATABASE__HOST=localhost
AI_SRE_DATABASE__PORT=5432
AI_SRE_DATABASE__USERNAME=postgres
AI_SRE_DATABASE__PASSWORD=postgres
AI_SRE_DATABASE__DATABASE=aisre
AI_SRE_DATABASE__POOL_MIN_SIZE=5
AI_SRE_DATABASE__POOL_MAX_SIZE=20
AI_SRE_DATABASE__SSL_MODE=disable
AI_SRE_DATABASE__TIMESCALE_ENABLED=true

# ---------- Redis ----------
AI_SRE_REDIS__HOST=localhost
AI_SRE_REDIS__PORT=6379
AI_SRE_REDIS__PASSWORD=       # leave empty if no password
AI_SRE_REDIS__DB=0
AI_SRE_REDIS__MAX_CONNECTIONS=20

# ---------- Qdrant (Vector DB) ----------
AI_SRE_VECTOR_DB__HOST=localhost
AI_SRE_VECTOR_DB__PORT=6333
AI_SRE_VECTOR_DB__GRPC_PORT=6334
AI_SRE_VECTOR_DB__API_KEY=    # optional
AI_SRE_VECTOR_DB__EMBEDDING_DIMENSION=1536
AI_SRE_VECTOR_DB__COLLECTION_NAME_PREFIX=ai_sre

# ---------- LLM (OpenAI / Azure / Anthropic) ----------
AI_SRE_LLM__DEFAULT_MODEL=gpt-4o-mini
AI_SRE_LLM__AZURE_ENDPOINT=     # optional
AI_SRE_LLM__AZURE_API_KEY=      # optional
AI_SRE_LLM__AZURE_DEPLOYMENT=   # optional
AI_SRE_LLM__OPENAI_API_KEY=sk-...   # required if using OpenAI
AI_SRE_LLM__ANTHROPIC_API_KEY=      # optional
AI_SRE_LLM__TEMPERATURE=0.2
AI_SRE_LLM__REQUEST_TIMEOUT=60
AI_SRE_LLM__MAX_TOKENS=4096

# ---------- Hostinger (optional initially) ----------
AI_SRE_HOSTINGER__API_BASE_URL=https://api.hostinger.com/v1
AI_SRE_HOSTINGER__API_TOKEN=      # optional
AI_SRE_HOSTINGER__SSH_KEY_PATH=/home/user/.ssh/id_rsa
AI_SRE_HOSTINGER__SSH_USERNAME=root

# ---------- Feature Flags ----------
AI_SRE_FEATURES__ENABLE_AUTONOMOUS_EXECUTION=false
AI_SRE_FEATURES__ENABLE_LLM_RC=true
AI_SRE_FEATURES__ENABLE_VECTOR_KNOWLEDGE=true
AI_SRE_FEATURES__ENABLE_ANOMALY_DETECTION=true
AI_SRE_FEATURES__ENABLE_AUTO_REMEDIATION=false